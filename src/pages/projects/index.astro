---
const base = import.meta.env.BASE_URL;

const withBase = (path = "") => {
  if (!path) return "";
  if (/^(https?:)?\/\//.test(path) || path.startsWith("mailto:") || path.startsWith("#")) return path;
  const cleaned = path.startsWith("/") ? path.slice(1) : path;
  return `${base}${cleaned}`;
};

const projects = [
  {
    id: "coordination-integrity",
    title: "Coordination Integrity Monitoring for Human–AI Teams",
    status: "Active",
    phase: "Model development",
    summary:
      "A live research effort focused on monitoring coordination integrity in human–AI teams under uncertainty, with emphasis on telemetry analysis, nonlinear markers, and decision support.",
    tags: ["Human–AI teaming", "Telemetry", "Nonlinear dynamics"],
    timeline: "2026–2028",
    lead: "Abhishek Singharoy",
    team: [
      { name: "Abhishek Singharoy", role: "Principal Investigator", href: "people#abhishek-singharoy" },
      { name: "Caleb James Armstrong", role: "Research Scientist", href: "people#caleb-james-armstrong" },
      { name: "Chun Kit Chan", role: "Postdoctoral Research Scholar", href: "people#chun-kit-chan" },
    ],
    updates: [
      "Streaming telemetry preprocessing pipeline finalized.",
      "Initial anomaly signatures benchmarked across simulated conditions.",
    ],
  },
  {
    id: "mr-beam",
    title: "Mr. BEAM Drowsiness Monitoring Tool",
    status: "Active",
    phase: "Data collection",
    summary:
      "An applied machine learning project to support drowsiness monitoring through multimodal sensing, predictive analytics, and adaptive feedback design.",
    tags: ["Machine learning", "Driver readiness", "Wearables"],
    timeline: "2025–2027",
    lead: "Caleb James Armstrong",
    team: [
      { name: "Caleb James Armstrong", role: "Project Lead", href: "people#caleb-james-armstrong" },
      { name: "Abhishek Singharoy", role: "Principal Investigator", href: "people#abhishek-singharoy" },
      { name: "Graduate Research Team", role: "Modeling and validation", href: "people" },
    ],
    updates: [
      "Ground-truth workflow refined for pilot participants.",
      "Feature extraction and readiness modeling currently underway.",
    ],
  },
  {
    id: "mhelp",
    title: "mHelp Digital Health Platform",
    status: "Active",
    phase: "Validation and deployment planning",
    summary:
      "A digital health initiative combining sensing, self-management support, and predictive analytics to improve stress monitoring and intervention workflows.",
    tags: ["Digital health", "Stress detection", "Intervention design"],
    timeline: "2025–2026",
    lead: "Caleb James Armstrong",
    team: [
      { name: "Caleb James Armstrong", role: "Research Scientist", href: "people#caleb-james-armstrong" },
      { name: "Chun Kit Chan", role: "Computational and ML Support", href: "people#chun-kit-chan" },
      { name: "Clinical and ML Teams", role: "Clinical implementation and model support", href: "people" },
    ],
    updates: [
      "Daily survey integration and lag-effect modeling in progress.",
      "Pilot visualizations prepared for outcome review.",
    ],
  },
];

const stats = [
  { label: "Active Projects", value: String(projects.length) },
  { label: "Research Areas", value: "6+" },
  { label: "Team Members", value: "10+" },
  { label: "Partner Sites", value: "Multi-site" },
];

const navItems = [
  { label: "Home", href: `${base}` },
  { label: "People", href: `${base}/people` },
  { label: "Research", href: `${base}/research` },
  { label: "Projects", href: `${base}/projects` },
  { label: "Publications", href: `${base}/publications` },
  { label: "News", href: `${base}/news` },
  { label: "Join", href: `${base}/join` },
  { label: "Contact", href: `${base}/contact` },
];

const pathname = Astro.url.pathname;

const stripBase = (path) => {
  if (base !== "/" && path.startsWith(base)) {
    return path.slice(base.length - 1);
  }
  return path;
};

const localPath = stripBase(pathname);

const active = (href) => {
  const localHref = stripBase(href);
  return localHref === "/" ? localPath === "/" : localPath.startsWith(localHref);
};
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.9); }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246,247,251,.78);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,.06);
  }

  .navWrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: .9rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: .75rem;
    text-decoration: none;
    color: rgba(0,0,0,.92);
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 1.08rem;
    white-space: nowrap;
  }

  .brandText strong { font-weight: 900; }

  .logoWrap{
    position: relative;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    padding: 3px;
    background:
      radial-gradient(24px 24px at 30% 20%, rgba(99,102,241,.40), transparent 65%),
      radial-gradient(28px 28px at 80% 30%, rgba(56,189,248,.35), transparent 60%),
      radial-gradient(30px 30px at 60% 85%, rgba(16,185,129,.28), transparent 62%),
      rgba(255,255,255,.60);
    border: 1px solid rgba(0,0,0,.08);
    box-shadow: 0 10px 18px rgba(0,0,0,.10);
    flex: 0 0 auto;
  }

  .logo{
    width: 100%;
    height: 100%;
    border-radius: 12px;
    object-fit: cover;
    display: block;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.80);
  }

  .navLinks {
    display: flex;
    align-items: center;
    gap: .35rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .navA {
    text-decoration: none;
    font-size: 0.98rem;
    padding: .45rem .72rem;
    border-radius: 999px;
    color: rgba(0,0,0,.78);
    border: 1px solid transparent;
    transition: background .15s ease, border-color .15s ease, transform .15s ease;
  }

  .navA:hover {
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.07);
    transform: translateY(-1px);
  }

  .navA.active {
    background: rgba(0,0,0,.06);
    border-color: rgba(0,0,0,.10);
    color: rgba(0,0,0,.9);
    font-weight: 700;
  }

  .menuBtn {
    display: none;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.85);
    border-radius: 999px;
    padding: .5rem .75rem;
    font-size: 0.95rem;
    cursor: pointer;
  }

  @media (max-width: 820px) {
    .menuBtn { display: inline-flex; align-items: center; gap: .45rem; }
    .navLinks { display: none; width: 100%; margin-top: .75rem; }
    .navLinks.open { display: flex; }
    .navWrap { flex-wrap: wrap; align-items: flex-start; }
  }

  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.25rem 1.25rem 3rem 1.25rem;
  }

  .hero {
    border-radius: 26px;
    padding: 2.6rem 2rem;
    background:
      radial-gradient(1200px 420px at 12% 10%, rgba(99,102,241,.24), transparent 60%),
      radial-gradient(900px 420px at 90% 0%, rgba(56,189,248,.20), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.74));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    margin-bottom: 2rem;
  }

  .heroGrid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1.3fr .9fr;
    align-items: center;
  }

  .kicker {
    font-size: 0.92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem 0;
  }

  h1 {
    font-size: 3rem;
    line-height: 1.04;
    margin: 0 0 .8rem 0;
    letter-spacing: -0.02em;
  }

  .sub {
    font-size: 1.16rem;
    line-height: 1.6;
    color: rgba(0,0,0,.72);
    max-width: 66ch;
    margin: 0;
  }

  .heroButtons {
    display: flex;
    gap: .8rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .82rem 1.1rem;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 700;
    font-size: .98rem;
    border: 1px solid rgba(0,0,0,.10);
    transition: transform .15s ease, background .15s ease;
  }

  .btn:hover { transform: translateY(-1px); }
  .btnPrimary {
    background: #111827;
    color: white;
    border-color: #111827;
  }
  .btnSecondary {
    background: white;
    color: #111827;
  }

  .statsGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }

  .statCard {
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    padding: 1rem;
  }

  .statLabel {
    font-size: .92rem;
    color: rgba(0,0,0,.55);
    margin: 0 0 .35rem 0;
  }

  .statValue {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .section {
    margin-top: 1.7rem;
  }

  .sectionGrid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1.1fr .9fr;
  }

  .card {
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.5rem;
  }

  .cardDark {
    background: #111827;
    color: white;
    border-color: rgba(255,255,255,.06);
  }

  .sectionKicker {
    font-size: 0.84rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: rgba(0,0,0,.5);
    margin: 0 0 .45rem 0;
    font-weight: 700;
  }

  .cardDark .sectionKicker {
    color: rgba(255,255,255,.55);
  }

  .sectionTitle {
    margin: 0;
    font-size: 2rem;
    letter-spacing: -0.02em;
  }

  .bodyText {
    margin-top: .9rem;
    line-height: 1.7;
    color: rgba(0,0,0,.72);
    font-size: 1.02rem;
  }

  .cardDark .bodyText {
    color: rgba(255,255,255,.8);
  }

  .miniGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
    margin-top: 1rem;
  }

  .miniCard {
    background: rgba(0,0,0,.03);
    border-radius: 18px;
    padding: 1rem;
  }

  .miniTitle {
    margin: 0;
    font-weight: 700;
    font-size: .98rem;
  }

  .miniText {
    margin: .45rem 0 0 0;
    color: rgba(0,0,0,.68);
    line-height: 1.55;
    font-size: .95rem;
  }

  .cardDark .miniCard {
    background: rgba(255,255,255,.06);
  }

  .cardDark .miniText {
    color: rgba(255,255,255,.76);
  }

  .projectsGrid {
    display: grid;
    gap: 1.25rem;
  }

  .projectCard {
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.5rem;
  }

  .projectGrid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1.1fr .9fr;
  }

  .statusRow {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: .8rem;
  }

  .badge {
    border-radius: 999px;
    padding: .42rem .8rem;
    font-size: .9rem;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.03);
    font-weight: 700;
  }

  .badgeActive {
    background: #ecfdf5;
    border-color: #bbf7d0;
    color: #047857;
  }

  .projectTitle {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .projectText {
    margin: .85rem 0 0 0;
    color: rgba(0,0,0,.7);
    line-height: 1.7;
    font-size: 1rem;
  }

  .tagRow {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: 1rem;
  }

  .tag {
    border-radius: 999px;
    padding: .38rem .75rem;
    font-size: .9rem;
    border: 1px solid rgba(0,0,0,.08);
    background: white;
    color: rgba(0,0,0,.72);
  }

  .metaGrid {
    display: grid;
    gap: .8rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .metaCard,
  .sideCard {
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,.06);
    background: rgba(0,0,0,.02);
    padding: 1rem;
  }

  .metaLabel,
  .sideLabel {
    margin: 0;
    font-size: .88rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(0,0,0,.5);
    font-weight: 700;
  }

  .metaValue {
    margin: .45rem 0 0 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .sideStack {
    display: grid;
    gap: .9rem;
  }

  .memberLink {
    display: block;
    text-decoration: none;
    border-radius: 16px;
    padding: .85rem 1rem;
    background: white;
    border: 1px solid rgba(0,0,0,.07);
    transition: transform .15s ease, background .15s ease;
  }

  .memberLink:hover {
    transform: translateY(-1px);
    background: rgba(0,0,0,.02);
  }

  .memberName {
    margin: 0;
    font-size: .98rem;
    font-weight: 700;
    color: rgba(0,0,0,.88);
  }

  .memberRole {
    margin: .25rem 0 0 0;
    color: rgba(0,0,0,.62);
    font-size: .93rem;
  }

  .progressList {
    margin: .7rem 0 0 0;
    padding-left: 1.1rem;
    color: rgba(0,0,0,.68);
    line-height: 1.7;
  }

  .footer {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2rem 1.25rem 2.5rem 1.25rem;
    color: rgba(0,0,0,.6);
    font-size: 0.95rem;
  }

  .footerRow {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid rgba(0,0,0,.08);
    padding-top: 1.25rem;
  }

  .footerBrand {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
  }

  .footerLogo {
    width: 28px;
    height: 28px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(255,255,255,.8);
  }

  .footerLinks { display: flex; gap: .9rem; flex-wrap: wrap; }
  .footerLinks a { color: rgba(0,0,0,.65); text-decoration: none; }
  .footerLinks a:hover { text-decoration: underline; }

  @media (max-width: 1000px) {
    .heroGrid,
    .sectionGrid,
    .projectGrid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    h1 { font-size: 2.3rem; }
    .hero { padding: 2rem 1.2rem; }
    .wrap { padding: 1.5rem 1rem 2.2rem 1rem; }
    .statsGrid,
    .miniGrid,
    .metaGrid {
      grid-template-columns: 1fr;
    }
  }
</style>

<header class="topbar">
  <div class="navWrap">
    <a class="brand" href={base}>
      <span class="logoWrap" aria-hidden="true">
        <img class="logo" src={`${base}uploads/logo.png`} alt="" />
      </span>
      <span class="brandText"><strong>Systems</strong> Structural Biology Group</span>
    </a>

    <button class="menuBtn" type="button" data-menu-btn aria-expanded="false" aria-controls="mainnav">
      Menu
    </button>

    <nav id="mainnav" class="navLinks" aria-label="Main navigation" data-nav>
      {navItems.map((item) => (
        <a class={`navA ${active(item.href) ? "active" : ""}`} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<main class="wrap">
  <section class="hero">
    <div class="heroGrid">
      <div>
        <p class="kicker">Systems Structural Biology Group</p>
        <h1>Active Projects</h1>
        <p class="sub">
          A shared view of ongoing research, current progress, and project teams.
          Each project includes summary information, current phase, recent progress,
          and team members linked to the People page.
        </p>

        <div class="heroButtons">
          <a href="#projects" class="btn btnPrimary">Browse projects</a>
          <a href={`${base}people`} class="btn btnSecondary">View people</a>
        </div>
      </div>

      <div class="statsGrid">
        {stats.map((stat) => (
          <div class="statCard">
            <p class="statLabel">{stat.label}</p>
            <p class="statValue">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="overview" class="section">
    <div class="sectionGrid">
      <div class="card">
        <p class="sectionKicker">Overview</p>
        <h2 class="sectionTitle">How this page is organized</h2>
        <p class="bodyText">
          Each active project is presented as a structured card with summary information,
          status, timeline, lead, recent updates, and associated personnel. Team members
          are linked to the People page so visitors can move easily between project-level
          and person-level information.
        </p>

        <div class="miniGrid">
          <div class="miniCard">
            <p class="miniTitle">What each project shows</p>
            <p class="miniText">
              Summary, current phase, status, timeline, lead, team members, and recent progress items.
            </p>
          </div>
          <div class="miniCard">
            <p class="miniTitle">Why it helps</p>
            <p class="miniText">
              Provides a clean public-facing overview of the lab’s ongoing work and who contributes to each effort.
            </p>
          </div>
        </div>
      </div>

      <div class="card cardDark">
        <p class="sectionKicker">Design goal</p>
        <h2 class="sectionTitle">Project visibility</h2>
        <p class="bodyText">
          This page is intended to serve as a general active-projects hub for a lab website,
          grant website, or public-facing project portfolio.
        </p>

        <div class="miniGrid">
          <div class="miniCard">
            <p class="miniTitle">Navigation</p>
            <p class="miniText">Connected directly to individual bios.</p>
          </div>
          <div class="miniCard">
            <p class="miniTitle">Use case</p>
            <p class="miniText">Lab website, grant page, or project portfolio.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="projects" class="section">
    <div class="projectsGrid">
      {projects.map((project) => (
        <article class="projectCard" id={project.id}>
          <div class="projectGrid">
            <div>
              <div class="statusRow">
                <span class="badge badgeActive">{project.status}</span>
                <span class="badge">{project.phase}</span>
              </div>

              <h2 class="projectTitle">{project.title}</h2>
              <p class="projectText">{project.summary}</p>

              <div class="tagRow">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>

              <div class="metaGrid">
                <div class="metaCard">
                  <p class="metaLabel">Timeline</p>
                  <p class="metaValue">{project.timeline}</p>
                </div>
                <div class="metaCard">
                  <p class="metaLabel">Lead</p>
                  <p class="metaValue">{project.lead}</p>
                </div>
              </div>
            </div>

            <div class="sideStack">
              <div class="sideCard">
                <p class="sideLabel">Team members</p>
                <div style="margin-top:.8rem; display:grid; gap:.65rem;">
                  {project.team.map((member) => (
                    <a href={withBase(member.href)} class="memberLink">
                      <p class="memberName">{member.name}</p>
                      <p class="memberRole">{member.role}</p>
                    </a>
                  ))}
                </div>
              </div>

              <div class="sideCard">
                <p class="sideLabel">Recent progress</p>
                <ul class="progressList">
                  {project.updates.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</main>

<footer class="footer">
  <div class="footerRow">
    <div class="footerBrand">
      <img class="footerLogo" src={`${base}uploads/logo.png`} alt="Systems Structural Biology Group logo" />
      <div>© {new Date().getFullYear()} Systems Structural Biology Group</div>
    </div>
    <div class="footerLinks">
      <a href={`${base}people`}>People</a>
      <a href={`${base}publications`}>Publications</a>
      <a href={`${base}join`}>Join</a>
      <a href={`${base}contact`}>Contact</a>
    </div>
  </div>
</footer>

<script>
  const btn = document.querySelector("[data-menu-btn]");
  const nav = document.querySelector("[data-nav]");
  if (btn && nav) {
    btn.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("open");
      btn.setAttribute("aria-expanded", String(isOpen));
    });
  }
</script>