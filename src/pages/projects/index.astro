---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { uploadPath, withBase as withSiteBase } from "../../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);
const assetPath = (path = "") => uploadPath(base, path);

const projects = [
  {
    id: "ai-tutor-teammate",
    title: "AI Tutor Teammate for Interactive Molecular Dynamics",
    status: "Active",
    phase: "Project development",
    summary:
      "This project extends the AI tutor teammate idea from the attached paper into an interactive molecular dynamics learning and discovery environment, focusing on how adaptive artificial intelligence can support curiosity, human decision-making, and scientific exploration.",
    topics: ["Human-centered data science", "Complex systems", "Structural biology"],
    tags: ["Human-AI teaming", "Interactive Molecular Dynamics", "Discovery Curiosity", "Adaptive AI", "Learning Analytics"],
    timeline: "2024-2026",
    lead: "Caleb James Armstrong, Abhishek Singharoy",
    links: [
      {
        label: "BioSense Network",
        description:
          "A connected BioSense community for translating complex biology and health data into clearer, actionable guidance.",
        href: "https://biosense.mn.co/?utm_campaign=welcome_to_space&utm_medium=email&utm_source=transactional_emails",
      },
    ],
    team: [
      { name: "Caleb James Armstrong", role: "Co-Lead", href: "people#caleb-james-armstrong" },
      { name: "Abhishek Singharoy", role: "PI", href: "people#abhishek-singharoy" },
    ],
    updates: [
      "Project concept grounded in the AI tutor teammate paper on discovery curiosity and interactive molecular dynamics",
      "Initial project scope added to the lab projects portfolio",
    ],
  },
  {
    id: "biotransformer",
    title: "Biophysical Transformer",
    status: "Active",
    phase: "Ablation Studies",
    summary:
      "The goal of the Biophysical Transformer is to leverage physical notions of protein interactions as the basis for a language model, creating a joint physics-sequence space for downstream applications.",
    topics: ["Structural biology", "Complex systems", "Human-centered data science"],
    tags: ["Deep Learning", "Biophysics", "Electrostatics", "SE3 Convolutional Networks"],
    timeline: "2025-2027",
    lead: "Abhishek Singharoy",
    team: [
      { name: "Abhishek Singharoy", role: "PI", href: "people#abhishek-singharoy" },
      { name: "Patrick Jiang", role: "Graduate Student", href: "people#patrick-h-jiang" },
    ],
    updates: ["Moved training to Wheat Supercomputers"],
  },
  {
    id: "mayod3",
    title: "Mayo Moonshot (D3)",
    status: "Active",
    phase: "In-Vitro Validation",
    summary:
      "The goal of the D3 moonshot project is to create anti-dimerization binders for FGFR systems using state-of-the-art binder generation methods along with cutting edge simulation methods.",
    topics: ["Structural biology", "Complex systems"],
    media: {
      type: "image",
      src: "uploads/brownian-ratchets-motors.png",
      alt: "Brownian-ratchet motor mechanisms visualization.",
    },
    tags: ["Applied Deep Learning", "Biophysics", "MELD", "Thermodynamic Ensembles", "Brownian Dynamics"],
    timeline: "2025-2027",
    lead: "Abhishek Singharoy, Mitesh Borad",
    team: [
      { name: "Abhishek Singharoy", role: "PI", href: "people#abhishek-singharoy" },
      { name: "Mitesh Borad", role: "PI", href: "collab#mitesh-borad" },
      { name: "Soumya Dutta", role: "PhD Student", href: "people#soumya-dutta" },
      { name: "Patrick Jiang", role: "Graduate Student", href: "people#patrick-h-jiang" },
      { name: "Paarth Batra", role: "ML Engineer", href: "people#paarth-batra" },
    ],
    updates: [
      "Finished generation of binders",
      "Starting large-scale BD simulations for validation",
      "Setting up wet-lab for protein purification",
    ],
  },
  {
    id: "confgen",
    title: "Learning to Predict Ensembles of Protein Conformations from Molecular Dynamics Simulation Trajectories",
    status: "Active",
    phase: "Hidden",
    summary:
      "Given the success of methods like BioEmu, can we generate thermodynamic ensembles from sequence alone?",
    topics: ["Structural biology", "Complex systems", "Human-centered data science"],
    tags: ["Deep Learning", "MELD", "Thermodynamic Ensembles", "Molecular Dynamics", "Structure Prediction"],
    timeline: "2023-2026",
    lead: "Abhishek Singharoy, Tristan Bepler",
    team: [
      { name: "Abhishek Singharoy", role: "PI", href: "people#abhishek-singharoy" },
      { name: "Tristan Bepler", role: "PI", href: "collab#tristan-bepler" },
      { name: "Bongjin Koo", role: "Research Scientist", href: "collab#bongjin-koo" },
      { name: "Soumya Dutta", role: "PhD Student", href: "people#soumya-dutta" },
      { name: "Patrick Jiang", role: "Graduate Student", href: "people#patrick-h-jiang" },
    ],
    updates: ["Generated new datasets with MELD and did some energy calculations"],
  },
  {
    id: "precure",
    title: "Disease Associations of HLA-class molecules from Learned Biophysical Representations",
    status: "Active",
    phase: "Model Testing and Fine Tuning",
    summary:
      "HLA-I has disease associations which can be revealed through biophysics. We hope to extend this work to HLA-II molecules.",
    topics: ["Structural biology", "Human-centered data science"],
    tags: ["Deep Learning", "Biophysics", "Electrostatics", "Healthcare", "Immunology", "Applied Deep Learning"],
    timeline: "2025-2027",
    lead: "Abhishek Singharoy",
    team: [
      { name: "Abhishek Singharoy", role: "PI", href: "people#abhishek-singharoy" },
      { name: "Akshaunsh Kaushik", role: "PhD Student", href: "people#akshaunsh-kaushik" },
      { name: "Patrick Jiang", role: "Graduate Student", href: "people#patrick-h-jiang" },
    ],
    updates: ["Finishing training on HLA-II embeddings, creating tests to compare against SOTA"],
  },
];

const stats = [
  { label: "Active Projects", value: String(projects.length) },
  { label: "Research Areas", value: "6+" },
  { label: "Team Members", value: "10+" },
  { label: "Partner Sites", value: "Multi-site" },
];

const projectTopics = [
  {
    id: "topic-structural-biology",
    label: "Structural biology",
    description: "Projects that connect biological structure, molecular interactions, and biophysical mechanisms.",
  },
  {
    id: "topic-complex-systems",
    label: "Complex systems",
    description: "Projects focused on emergent behavior across interacting proteins, ensembles, and multiscale systems.",
  },
  {
    id: "topic-human-centered-data-science",
    label: "Human-centered data science",
    description: "Projects that use machine learning and data-driven representations to support discovery and translational decisions.",
  },
].map((topic) => ({
  ...topic,
  projects: projects.filter((project) => project.topics?.includes(topic.label)),
}));
---

<style>
  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.25rem 1.25rem 3rem;
  }

  .hero {
    border-radius: 26px;
    padding: 2.6rem 2rem;
    background:
      radial-gradient(1200px 420px at 12% 10%, rgba(99,102,241,.24), transparent 60%),
      radial-gradient(900px 420px at 90% 0%, rgba(56,189,248,.20), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.74));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    margin-bottom: 1.7rem;
  }

  .heroGrid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1.3fr .9fr;
    align-items: center;
  }

  .kicker {
    font-size: 0.92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem;
  }

  h1 {
    margin: 0;
    font-size: 3.15rem;
    line-height: 1.03;
    letter-spacing: -0.03em;
  }

  .sub {
    max-width: 760px;
    margin: .9rem 0 0;
    color: rgba(0,0,0,.68);
    font-size: 1.14rem;
    line-height: 1.65;
  }

  .heroButtons {
    display: flex;
    gap: .8rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .82rem 1.1rem;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 700;
    font-size: .98rem;
    border: 1px solid rgba(0,0,0,.10);
    transition: transform .15s ease, background .15s ease;
  }
  .btn:hover { transform: translateY(-1px); }
  .btnPrimary {
    background: #111827;
    color: white;
    border-color: #111827;
  }
  .btnSecondary {
    background: white;
    color: #111827;
  }

  .statsGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }

  .statCard {
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    padding: 1rem;
  }

  .statLabel {
    font-size: .92rem;
    color: rgba(0,0,0,.55);
    margin: 0 0 .35rem;
  }

  .statValue {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .section {
    margin-top: 1.7rem;
  }

  .topicShell {
    border-radius: 28px;
    padding: 1.25rem;
    background:
      radial-gradient(900px 420px at 8% 0%, rgba(16,185,129,.12), transparent 55%),
      radial-gradient(760px 380px at 92% 0%, rgba(99,102,241,.12), transparent 55%),
      rgba(255,255,255,.64);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 14px 34px rgba(0,0,0,.06);
    margin-bottom: 1.25rem;
  }

  .topicHeader {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .topicEyebrow {
    margin: 0 0 .35rem;
    color: rgba(0,0,0,.52);
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .topicHeader h2 {
    margin: 0;
    font-size: 1.55rem;
    letter-spacing: -0.02em;
  }

  .topicIntro {
    max-width: 58ch;
    margin: 0;
    color: rgba(0,0,0,.66);
    line-height: 1.6;
  }

  .topicGrid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .topicCard {
    scroll-margin-top: 96px;
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.2rem;
    min-height: 100%;
  }

  .topicCard h2 {
    margin: 0;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }

  .topicCard p {
    margin: .55rem 0 0;
    color: rgba(0,0,0,.68);
    line-height: 1.6;
  }

  .topicProjectList {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: .9rem;
  }

  .topicProjectLink {
    display: inline-flex;
    align-items: center;
    color: rgba(0,0,0,.86);
    text-decoration: none;
    font-weight: 700;
    border-radius: 999px;
    padding: .5rem .72rem;
    background: rgba(246,247,251,.92);
    border: 1px solid rgba(0,0,0,.06);
    font-size: .9rem;
    line-height: 1.25;
    max-width: 100%;
  }

  .topicProjectLink:hover {
    background: rgba(255,255,255,.95);
    border-color: rgba(0,0,0,.14);
  }

  .projectsGrid {
    display: grid;
    gap: 1.25rem;
  }

  .projectCard {
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.5rem;
  }

  .projectGrid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1.1fr .9fr;
  }

  .statusRow {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: .8rem;
  }

  .badge {
    border-radius: 999px;
    padding: .42rem .8rem;
    font-size: .9rem;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.03);
    font-weight: 700;
  }

  .badgeActive {
    background: #ecfdf5;
    border-color: #bbf7d0;
    color: #047857;
  }

  .projectTitle {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .projectText {
    margin: .85rem 0 0;
    color: rgba(0,0,0,.7);
    line-height: 1.7;
    font-size: 1rem;
  }

  .projectLinks {
    display: grid;
    gap: .75rem;
    margin-top: 1rem;
  }

  .projectLinkCard {
    border-radius: 20px;
    padding: 1rem;
    background:
      radial-gradient(420px 160px at 10% 0%, rgba(16,185,129,.16), transparent 55%),
      rgba(255,255,255,.88);
    border: 1px solid rgba(0,0,0,.07);
    box-shadow: 0 12px 28px rgba(0,0,0,.06);
  }

  .projectLinkText {
    margin: 0 0 .75rem;
    color: rgba(0,0,0,.68);
    line-height: 1.55;
  }

  .projectLink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: .62rem .95rem;
    color: white;
    background: #111827;
    border: 1px solid rgba(0,0,0,.14);
    text-decoration: none;
    font-weight: 800;
    box-shadow: 0 12px 22px rgba(17,24,39,.14);
    transition: transform .15s ease, box-shadow .15s ease;
  }

  .projectLink:hover {
    transform: translateY(-1px);
    box-shadow: 0 16px 28px rgba(17,24,39,.18);
  }

  .mediaContainer {
    margin-top: 1rem;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.03);
  }

  .mediaContainer img,
  .mediaContainer video {
    display: block;
    width: 100%;
    max-height: 320px;
    object-fit: cover;
  }

  .tagRow {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: 1rem;
  }

  .tag {
    border-radius: 999px;
    padding: .38rem .75rem;
    font-size: .9rem;
    border: 1px solid rgba(0,0,0,.08);
    background: white;
    color: rgba(0,0,0,.72);
  }

  .metaGrid {
    display: grid;
    gap: .8rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .metaCard,
  .sideCard {
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,.06);
    background: rgba(0,0,0,.02);
    padding: 1rem;
  }

  .metaLabel,
  .sideLabel {
    margin: 0;
    font-size: .88rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(0,0,0,.5);
    font-weight: 700;
  }

  .metaValue {
    margin: .45rem 0 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .sideStack {
    display: grid;
    gap: .9rem;
  }

  .memberLink {
    display: block;
    text-decoration: none;
    border-radius: 16px;
    padding: .85rem 1rem;
    background: white;
    border: 1px solid rgba(0,0,0,.07);
    transition: transform .15s ease, background .15s ease;
  }

  .memberLink:hover {
    transform: translateY(-1px);
    background: rgba(0,0,0,.02);
  }

  .memberName {
    margin: 0;
    font-size: .98rem;
    font-weight: 700;
    color: rgba(0,0,0,.88);
  }

  .memberRole {
    margin: .25rem 0 0;
    color: rgba(0,0,0,.62);
    font-size: .93rem;
  }

  .progressList {
    margin: .7rem 0 0;
    padding-left: 1.1rem;
    color: rgba(0,0,0,.68);
    line-height: 1.7;
  }

  @media (max-width: 1000px) {
    .heroGrid,
    .topicGrid,
    .projectGrid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    h1 { font-size: 2.3rem; }
    .hero { padding: 2rem 1.2rem; }
    .wrap { padding: 1.5rem 1rem 2.2rem; }
    .topicShell { padding: 1rem; }
    .topicHeader { display: block; }
    .topicIntro { margin-top: .45rem; }
    .statsGrid,
    .metaGrid {
      grid-template-columns: 1fr;
    }
  }
</style>

<SiteLayout title="Projects | Systems Structural Biology Group">
  <main class="wrap">
    <section class="hero">
      <div class="heroGrid">
        <div>
          <p class="kicker">Systems Structural Biology Group</p>
          <h1>Active Projects</h1>
          <p class="sub">A shared view of ongoing research, current progress, and project teams.</p>

          <div class="heroButtons">
            <a href="#projects" class="btn btnPrimary">Browse projects</a>
            <a href={withBase("/people")} class="btn btnSecondary">View people</a>
          </div>
        </div>

        <div class="statsGrid">
          {stats.map((stat) => (
            <div class="statCard">
              <p class="statLabel">{stat.label}</p>
              <p class="statValue">{stat.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="section">
      <div class="topicShell">
        <div class="topicHeader">
          <div>
            <p class="topicEyebrow">Project keyword index</p>
          </div>
        </div>

        <div class="topicGrid" aria-label="Project topics">
          {projectTopics.map((topic) => (
            <article class="topicCard" id={topic.id}>
              <h2>{topic.label}</h2>
              <p>{topic.description}</p>
              <div class="topicProjectList">
                {topic.projects.map((project) => (
                  <a class="topicProjectLink" href={`#${project.id}`}>{project.title}</a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="projectsGrid">
        {projects.map((project) => (
          <article class="projectCard" id={project.id}>
            <div class="projectGrid">
              <div>
                <div class="statusRow">
                  <span class="badge badgeActive">{project.status}</span>
                  <span class="badge">{project.phase}</span>
                </div>

                <h2 class="projectTitle">{project.title}</h2>
                <p class="projectText">{project.summary}</p>

                {project.links && (
                  <div class="projectLinks">
                    {project.links.map((link) => (
                      <div class="projectLinkCard">
                        <p class="projectLinkText">{link.description}</p>
                        <a class="projectLink" href={link.href} target="_blank" rel="noopener noreferrer">
                          {link.label}
                        </a>
                      </div>
                    ))}
                  </div>
                )}

                {project.media && (
                  <div class="mediaContainer">
                    {project.media.type === "video" ? (
                      <video src={assetPath(project.media.src)} controls muted loop playsinline>
                        Your browser does not support the video tag.
                      </video>
                    ) : (
                      <img src={assetPath(project.media.src)} alt={project.media.alt} loading="lazy" />
                    )}
                  </div>
                )}

                <div class="tagRow">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>

                <div class="metaGrid">
                  <div class="metaCard">
                    <p class="metaLabel">Timeline</p>
                    <p class="metaValue">{project.timeline}</p>
                  </div>
                  <div class="metaCard">
                    <p class="metaLabel">Lead</p>
                    <p class="metaValue">{project.lead}</p>
                  </div>
                </div>
              </div>

              <div class="sideStack">
                <div class="sideCard">
                  <p class="sideLabel">Team members</p>
                  <div style="margin-top:.8rem; display:grid; gap:.65rem;">
                    {project.team.map((member) => (
                      <a href={withBase(member.href)} class="memberLink">
                        <p class="memberName">{member.name}</p>
                        <p class="memberRole">{member.role}</p>
                      </a>
                    ))}
                  </div>
                </div>

                <div class="sideCard">
                  <p class="sideLabel">Recent progress</p>
                  <ul class="progressList">
                    {project.updates.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>
