---
// src/pages/index.astro
// Home page for "Systems Structural Biology Group"

const base = import.meta.env.BASE_URL;

const navItems = [
  { label: "Home", href: `${base}` },
  { label: "People", href: `${base}/people` },
  { label: "Research", href: `${base}/research` },
  { label: "Projects", href: `${base}/projects` },
  { label: "Publications", href: `${base}/publications` },
  { label: "News", href: `${base}/news` },
  { label: "Join", href: `${base}/join` },
  { label: "Contact", href: `${base}/contact` },
];

const pathname = Astro.url.pathname;

const stripBase = (path) => {
  if (base !== "/" && path.startsWith(base)) {
    return path.slice(base.length - 1);
  }
  return path;
};

const localPath = stripBase(pathname);

const active = (href) => {
  const localHref = stripBase(href);
  return localHref === "/" ? localPath === "/" : localPath.startsWith(localHref);
};
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.92); }

  /* ---------- Top nav ---------- */
  .topbar{
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246,247,251,.78);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .navWrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: .9rem 1.25rem;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand{
    display:inline-flex;
    align-items:center;
    gap:.75rem;
    text-decoration:none;
    color: rgba(0,0,0,.92);
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 1.08rem;
    white-space: nowrap;
    outline: none;
  }
  .brandText strong { font-weight: 900; }

  /* --- Interactive logo --- */
  .logoWrap{
    position: relative;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    padding: 3px;
    background:
      radial-gradient(24px 24px at 30% 20%, rgba(99,102,241,.40), transparent 65%),
      radial-gradient(28px 28px at 80% 30%, rgba(56,189,248,.35), transparent 60%),
      radial-gradient(30px 30px at 60% 85%, rgba(16,185,129,.28), transparent 62%),
      rgba(255,255,255,.60);
    border: 1px solid rgba(0,0,0,.08);
    box-shadow: 0 10px 18px rgba(0,0,0,.10);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    transform-style: preserve-3d;
    flex: 0 0 auto;
  }
  .logo{
    width:100%;
    height:100%;
    border-radius: 12px;
    object-fit: cover;
    display:block;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.80);
    transition: transform .18s ease, filter .18s ease;
  }
  .logoWrap::after{
    content:"";
    position:absolute;
    inset:-6px;
    border-radius: 18px;
    background:
      radial-gradient(circle at 30% 20%, rgba(99,102,241,.28), transparent 55%),
      radial-gradient(circle at 80% 30%, rgba(56,189,248,.22), transparent 55%),
      radial-gradient(circle at 60% 85%, rgba(16,185,129,.18), transparent 55%);
    opacity: 0;
    filter: blur(6px);
    transition: opacity .18s ease;
    pointer-events:none;
  }
  .brand:hover .logoWrap,
  .brand:focus-visible .logoWrap{
    transform: translateY(-1px) rotateX(6deg) rotateY(-8deg);
    border-color: rgba(0,0,0,.14);
    box-shadow: 0 16px 30px rgba(0,0,0,.16);
  }
  .brand:hover .logo,
  .brand:focus-visible .logo{
    transform: scale(1.02);
    filter: saturate(1.08) contrast(1.04);
  }
  .brand:hover .logoWrap::after,
  .brand:focus-visible .logoWrap::after{
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce){
    .logoWrap, .logo, .logoWrap::after { transition: none; }
    .brand:hover .logoWrap, .brand:focus-visible .logoWrap { transform: none; }
  }

  .menuBtn{
    display:none;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.85);
    border-radius: 999px;
    padding: .5rem .75rem;
    font-size: .95rem;
    cursor:pointer;
  }

  .navLinks{
    display:flex;
    align-items:center;
    gap:.35rem;
    flex-wrap: wrap;
    justify-content:flex-end;
  }
  .navA{
    text-decoration:none;
    font-size: .98rem;
    padding: .45rem .72rem;
    border-radius: 999px;
    color: rgba(0,0,0,.78);
    border: 1px solid transparent;
    transition: background .15s ease, border-color .15s ease, transform .15s ease;
  }
  .navA:hover{
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.07);
    transform: translateY(-1px);
  }
  .navA.active{
    background: rgba(0,0,0,.06);
    border-color: rgba(0,0,0,.10);
    color: rgba(0,0,0,.9);
    font-weight: 700;
  }

  @media (max-width: 820px){
    .menuBtn{ display:inline-flex; align-items:center; gap:.45rem; }
    .navLinks{ display:none; width:100%; margin-top:.75rem; }
    .navLinks.open{ display:flex; }
  }

  /* ---------- Page layout ---------- */
  .wrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem 1.25rem;
  }

  /* Hero */
  .hero{
    border-radius: 28px;
    padding: 2.6rem 2.2rem;
    background:
      radial-gradient(1200px 520px at 12% 10%, rgba(99,102,241,.26), transparent 60%),
      radial-gradient(900px 520px at 90% 0%, rgba(56,189,248,.22), transparent 55%),
      radial-gradient(900px 520px at 50% 120%, rgba(16,185,129,.10), transparent 60%),
      linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.78));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 46px rgba(0,0,0,.09);
  }

  .kicker{
    font-size: .92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem 0;
  }
  h1{
    font-size: 3.05rem;
    line-height: 1.04;
    margin: 0 0 .85rem 0;
    letter-spacing: -0.02em;
  }
  .lead{
    font-size: 1.22rem;
    line-height: 1.6;
    color: rgba(0,0,0,.74);
    max-width: 78ch;
    margin: 0;
  }

  .chips{
    display:flex;
    flex-wrap:wrap;
    gap:.6rem;
    margin-top: 1.2rem;
  }
  .chip{
    font-size: 1rem;
    padding: .5rem .8rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.76);
    color: rgba(0,0,0,.72);
  }

  .ctaRow{
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
    margin-top: 1.35rem;
  }
  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.5rem;
    padding: .72rem 1.05rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.90);
    color: rgba(0,0,0,.86);
    text-decoration:none;
    font-size: 1.02rem;
    font-weight: 700;
    transition: transform .15s ease, background .15s ease, border-color .15s ease;
  }
  .btn:hover{
    transform: translateY(-1px);
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.14);
  }
  .btn.primary{
    background: rgba(0,0,0,.92);
    color: rgba(255,255,255,.95);
    border-color: rgba(0,0,0,.92);
  }
  .btn.primary:hover{
    background: rgba(0,0,0,.85);
  }

  /* Content grid */
  .grid{
    display:grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 1.25rem;
    margin-top: 1.35rem;
  }
  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
  }

  .card{
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.25rem 1.25rem 1.15rem 1.25rem;
  }
  .card h2{
    margin: 0 0 .6rem 0;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }
  .card p{
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.62;
    color: rgba(0,0,0,.74);
  }

  .list{
    margin: .8rem 0 0 0;
    padding-left: 1.05rem;
    color: rgba(0,0,0,.74);
    font-size: 1.03rem;
    line-height: 1.65;
  }
  .list li{ margin: .3rem 0; }

  .mini{
    display:grid;
    gap: 1rem;
  }
  .stat{
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.02);
    padding: 1rem 1.05rem;
  }
  .stat .label{
    font-size: .9rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .35rem 0;
  }
  .stat .value{
    font-size: 1.12rem;
    font-weight: 800;
    margin: 0;
    color: rgba(0,0,0,.86);
  }
  .stat .desc{
    margin: .45rem 0 0 0;
    color: rgba(0,0,0,.70);
    font-size: 1rem;
    line-height: 1.55;
  }

  /* Footer */
  .footer{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2rem 1.25rem 2.5rem 1.25rem;
    color: rgba(0,0,0,.6);
    font-size: .95rem;
  }
  .footerRow{
    display:flex;
    justify-content:space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid rgba(0,0,0,.08);
    padding-top: 1.25rem;
  }
  .footerBrand{
    display:inline-flex;
    align-items:center;
    gap:.6rem;
  }
  .footerLogo{
    width: 28px;
    height: 28px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(255,255,255,.8);
    transition: transform .18s ease, filter .18s ease;
  }
  .footerBrand:hover .footerLogo{
    transform: translateY(-1px) scale(1.03);
    filter: saturate(1.08) contrast(1.03);
  }
  .footerLinks{
    display:flex;
    gap:.9rem;
    flex-wrap: wrap;
  }
  .footerLinks a{
    color: rgba(0,0,0,.65);
    text-decoration:none;
  }
  .footerLinks a:hover{ text-decoration: underline; }

  @media (max-width: 640px){
    .wrap{ padding: 1.6rem 1rem 2.8rem 1rem; }
    .hero{ padding: 2.1rem 1.4rem; }
    h1{ font-size: 2.35rem; }
    .lead{ font-size: 1.12rem; }
  }
</style>

<header class="topbar">
  <div class="navWrap">
    <a class="brand" href={base}>
      <span class="logoWrap" aria-hidden="true">
        <img class="logo" src={`${base}uploads/logo.png`} alt="" />
      </span>
      <span class="brandText"><strong>Systems</strong> Structural Biology Group</span>
    </a>

    <button class="menuBtn" type="button" data-menu-btn aria-expanded="false" aria-controls="mainnav">
      Menu
    </button>

    <nav id="mainnav" class="navLinks" aria-label="Main navigation" data-nav>
      {navItems.map((item) => (
        <a class={`navA ${active(item.href) ? "active" : ""}`} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<main class="wrap">
  <section class="hero">
    <p class="kicker">Systems Structural Biology Group</p>
    <h1>Human-centered AI science for structural discovery and complex systems.</h1>
    <p class="lead">
      We build trustworthy computational methods that connect molecular structure, dynamics, and human decision-making,
      spanning structural biology, data science, and adaptive AI systems designed for real users.
    </p>

    <div class="chips">
      <span class="chip">Structural biology</span>
      <span class="chip">Complex systems</span>
      <span class="chip">Human-centered data science</span>
      <span class="chip">Nonlinear dynamics</span>
      <span class="chip">Interpretable AI</span>
    </div>

    <div class="ctaRow">
      <a class="btn primary" href={`${base}research`}>Explore Research</a>
      <a class="btn" href={`${base}people`}>Meet the Team</a>
      <a class="btn" href={`${base}join`}>Join the Lab</a>
    </div>
  </section>

  <section class="grid" aria-label="Home content">
    <div class="card">
      <h2>What we do</h2>
      <p>
        We unify simulation, learning, and human-centered design to study complex biological and sociotechnical systems.
        Our work spans molecular modeling and structural analysis, data-driven inference, and adaptive decision support.
      </p>
      <ul class="list">
        <li><strong>Structural biology & modeling:</strong> molecular simulation, multiscale structure–function analysis.</li>
        <li><strong>AI + data science:</strong> statistical learning, reliable inference, uncertainty-aware modeling.</li>
        <li><strong>Complex systems:</strong> dynamical systems methods and interpretable metrics for behavior over time.</li>
        <li><strong>Human-centered AI:</strong> usable, trustworthy tools for learning, health, and operational contexts.</li>
      </ul>
    </div>

    <div class="mini">
      <div class="stat">
        <p class="label">Mission</p>
        <p class="value">Trustworthy, usable AI for discovery</p>
        <p class="desc">
          Build human-centered AI and data science that turns complex signals into reliable insight and deployable tools.
        </p>
      </div>

      <div class="stat">
        <p class="label">Vision</p>
        <p class="value">Interpretability at scale</p>
        <p class="desc">
          Enable scientific and operational teams to understand, communicate, and act on complex systems with confidence.
        </p>
      </div>

      <div class="stat">
        <p class="label">Get involved</p>
        <p class="value">Students & collaborators welcome</p>
        <p class="desc">
          We support graduate/undergraduate research, internships, and cross-disciplinary collaborations.
        </p>
      </div>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="footerRow">
    <div class="footerBrand">
      <img class="footerLogo" src={`${base}uploads/logo.png`} alt="Systems Structural Biology Group logo" />
      <div>© {new Date().getFullYear()} Systems Structural Biology Group</div>
    </div>
    <div class="footerLinks">
      <a href={`${base}people`}>People</a>
      <a href={`${base}publications`}>Publications</a>
      <a href={`${base}join`}>Join</a>
      <a href={`${base}contact`}>Contact</a>
    </div>
  </div>
</footer>

<script>
  // Mobile nav toggle
  const btn = document.querySelector("[data-menu-btn]");
  const nav = document.querySelector("[data-nav]");
  if (btn && nav) {
    btn.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("open");
      btn.setAttribute("aria-expanded", String(isOpen));
    });
  }
</script>