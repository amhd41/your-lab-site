---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { publications } from "../../data/publications.js";

const normalizedPublications = publications
  .map((publication) => ({
    ...publication,
    year: Number(publication.year),
  }))
  .filter((publication) => Number.isInteger(publication.year) && publication.year > 0);

const sorted = [...normalizedPublications].sort((a, b) => {
  if (b.year !== a.year) return b.year - a.year;
  return a.title.localeCompare(b.title);
});

const grouped = sorted.reduce((acc, pub) => {
  const existing = acc.get(pub.year) ?? [];
  existing.push(pub);
  acc.set(pub.year, existing);
  return acc;
}, new Map());

const years = [...grouped.keys()].sort((a, b) => b - a);
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.92); }

  .topbar{
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246,247,251,.78);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .navWrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: .9rem 1.25rem;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand{
    display:inline-flex;
    align-items:center;
    gap:.75rem;
    text-decoration:none;
    color: rgba(0,0,0,.92);
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 1.08rem;
    white-space: nowrap;
    outline: none;
  }
  .brandText strong { font-weight: 900; }

  .logoWrap{
    position: relative;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    padding: 3px;
    background:
      radial-gradient(24px 24px at 30% 20%, rgba(99,102,241,.40), transparent 65%),
      radial-gradient(28px 28px at 80% 30%, rgba(56,189,248,.35), transparent 60%),
      radial-gradient(30px 30px at 60% 85%, rgba(16,185,129,.28), transparent 62%),
      rgba(255,255,255,.60);
    border: 1px solid rgba(0,0,0,.08);
    box-shadow: 0 10px 18px rgba(0,0,0,.10);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    transform-style: preserve-3d;
    flex: 0 0 auto;
  }
  .logo{
    width:100%;
    height:100%;
    border-radius: 12px;
    object-fit: cover;
    display:block;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.80);
  }

  .menuBtn{
    display:none;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.85);
    border-radius: 999px;
    padding: .5rem .75rem;
    font-size: .95rem;
    cursor:pointer;
  }

  .navLinks{
    display:flex;
    align-items:center;
    gap:.35rem;
    flex-wrap: wrap;
    justify-content:flex-end;
  }
  .navA{
    text-decoration:none;
    font-size: .98rem;
    padding: .45rem .72rem;
    border-radius: 999px;
    color: rgba(0,0,0,.78);
    border: 1px solid transparent;
    transition: background .15s ease, border-color .15s ease, transform .15s ease;
  }
  .navA:hover{
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.07);
    transform: translateY(-1px);
  }
  .navA.active{
    background: rgba(0,0,0,.06);
    border-color: rgba(0,0,0,.10);
    color: rgba(0,0,0,.9);
    font-weight: 700;
  }

  @media (max-width: 820px){
    .menuBtn{ display:inline-flex; align-items:center; gap:.45rem; }
    .navLinks{ display:none; width:100%; margin-top:.75rem; }
    .navLinks.open{ display:flex; }
  }

  .wrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem 1.25rem;
  }

  .hero{
    border-radius: 28px;
    padding: 2.5rem 2.2rem;
    background:
      radial-gradient(1200px 520px at 12% 10%, rgba(99,102,241,.22), transparent 60%),
      radial-gradient(900px 520px at 90% 0%, rgba(56,189,248,.18), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.80));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 46px rgba(0,0,0,.09);
  }

  .kicker{
    font-size: .92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem 0;
  }
  h1{
    font-size: 3rem;
    line-height: 1.04;
    margin: 0 0 .85rem 0;
    letter-spacing: -0.02em;
  }
  .lead{
    font-size: 1.16rem;
    line-height: 1.62;
    color: rgba(0,0,0,.74);
    max-width: 75ch;
    margin: 0;
  }
  .ctaRow{
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
    margin-top: 1.25rem;
  }
  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding: .72rem 1.05rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.90);
    color: rgba(0,0,0,.86);
    text-decoration:none;
    font-size: 1.02rem;
    font-weight: 700;
  }
  .btn.primary{
    background: rgba(0,0,0,.92);
    color: rgba(255,255,255,.95);
    border-color: rgba(0,0,0,.92);
  }

  .note{
    margin-top: 1rem;
    font-size: .97rem;
    color: rgba(0,0,0,.6);
  }

  .yearSection{
    margin-top: 1.35rem;
  }

  .yearHeader{
    margin: 0 0 .7rem 0;
    font-size: 1.6rem;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .yearCount{
    font-size: .96rem;
    font-weight: 600;
    color: rgba(0,0,0,.52);
  }

  .pubList{
    display:grid;
    gap: .95rem;
  }

  .pubCard{
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.1rem 1.15rem 1rem 1.15rem;
  }

  .pubTitle{
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.45;
    font-weight: 800;
  }

  .pubTitle a{
    color: rgba(0,0,0,.92);
    text-decoration: none;
  }
  .pubTitle a:hover{
    text-decoration: underline;
  }

  .pubAuthors{
    margin: .35rem 0 0 0;
    font-size: .98rem;
    line-height: 1.55;
    color: rgba(0,0,0,.72);
  }

  .pubMeta{
    margin: .35rem 0 0 0;
    font-size: .95rem;
    color: rgba(0,0,0,.58);
  }

  .footer{
    max-width: 1240px;
    margin: 0 auto;
    padding: 2rem 1.25rem 2.5rem 1.25rem;
    color: rgba(0,0,0,.6);
    font-size: .95rem;
  }
  .footerRow{
    display:flex;
    justify-content:space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid rgba(0,0,0,.08);
    padding-top: 1.25rem;
  }
  .footerBrand{
    display:inline-flex;
    align-items:center;
    gap:.6rem;
  }
  .footerLogo{
    width: 28px;
    height: 28px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(255,255,255,.8);
  }
  .footerLinks{
    display:flex;
    gap:.9rem;
    flex-wrap: wrap;
  }
  .footerLinks a{
    color: rgba(0,0,0,.65);
    text-decoration:none;
  }

  @media (max-width: 640px){
    .wrap{ padding: 1.6rem 1rem 2.8rem 1rem; }
    .hero{ padding: 2.1rem 1.4rem; }
    h1{ font-size: 2.3rem; }
    .lead{ font-size: 1.08rem; }
  }
</style>

<SiteLayout title="Publications | Systems Structural Biology Group">
<main class="wrap">
  <section class="hero">
    <p class="kicker">Publications</p>
    <h1>Selected publications.</h1>
    <p class="lead">
      This page highlights publications connected to the Systems Structural Biology Group.
      For the most complete and continuously updated list, use the Google Scholar profile link below.
    </p>

    <div class="ctaRow">
      <a
        class="btn primary"
        href="https://scholar.google.com/citations?hl=en&user=UnRHyFYAAAAJ&view_op=list_works&sortby=pubdate"
        target="_blank"
        rel="noopener noreferrer"
      >
        Full list on Google Scholar
      </a>
    </div>
  </section>

  {years.map((year) => (
    <section class="yearSection">
      <h2 class="yearHeader">
        <span>{year}</span>
        <span class="yearCount">
          {grouped.get(year)?.length === 1 ? "1 publication" : `${grouped.get(year)?.length} publications`}
        </span>
      </h2>
      <div class="pubList">
        {grouped.get(year)?.map((pub) => (
          <article class="pubCard">
            <h3 class="pubTitle">
              <a href={pub.link} target="_blank" rel="noopener noreferrer">{pub.title}</a>
            </h3>
            <p class="pubAuthors">{pub.authors}</p>
            <p class="pubMeta">
              {pub.venue} · {pub.type}{pub.note ? ` · ${pub.note}` : ""}
            </p>
          </article>
        ))}
      </div>
    </section>
  ))}
</main>
</SiteLayout>
