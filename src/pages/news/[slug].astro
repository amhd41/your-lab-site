---
import { getCollection, getEntry, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { uploadPath } from "../../lib/site";

export async function getStaticPaths() {
  const newsEntries = await getCollection("news");
  return newsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { slug: entry.slug },
  }));
}

const { slug } = Astro.props;
const base = import.meta.env.BASE_URL;
const entry = await getEntry("news", slug);

if (!entry) {
  throw new Error(`News article not found for slug: ${slug}`);
}

const { Content } = await render(entry);
const allEntries = (await getCollection("news"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentEntries = allEntries.filter((item) => item.id !== entry.id).slice(0, 3);
const assetPath = (path = "") => uploadPath(base, path);

const formatDate = (date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<style>
  .wrap{
    max-width: 980px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem;
  }
  .hero,
  .article,
  .recentCard{
    border-radius: 24px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
  }
  .hero{
    overflow: hidden;
  }
  .heroBody{
    padding: 1.6rem;
  }
  .kicker{
    margin: 0 0 .55rem;
    font-size: .9rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
  }
  h1{
    margin: 0;
    font-size: 2.8rem;
    line-height: 1.06;
    letter-spacing: -0.02em;
  }
  .meta{
    margin-top: .9rem;
    color: rgba(0,0,0,.58);
    display: flex;
    gap: .7rem;
    flex-wrap: wrap;
    font-size: .95rem;
  }
  .summary{
    margin: .95rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: rgba(0,0,0,.72);
  }
  .hero img{
    display: block;
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-top: 1px solid rgba(0,0,0,.06);
  }

  .article{
    margin-top: 1.25rem;
    padding: 1.6rem;
  }
  .article :global(p){
    margin: 0 0 1rem;
    font-size: 1.08rem;
    line-height: 1.8;
    color: rgba(0,0,0,.76);
  }
  .article :global(h2),
  .article :global(h3){
    margin: 1.5rem 0 .7rem;
    letter-spacing: -0.02em;
  }
  .article :global(ul){
    margin: 0 0 1rem 1.15rem;
    color: rgba(0,0,0,.76);
    line-height: 1.7;
  }

  .backLink{
    display: inline-flex;
    margin-top: 1rem;
    text-decoration: none;
    color: rgba(0,0,0,.72);
    font-weight: 700;
  }

  .recentSection{
    margin-top: 1.25rem;
  }
  .recentGrid{
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .recentCard{
    padding: 1.1rem;
  }
  .recentCard a{
    text-decoration: none;
    color: inherit;
  }
  .recentCard h2{
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.25;
  }
  .recentCard a:hover h2{
    text-decoration: underline;
  }
  .recentCard p{
    margin: .65rem 0 0;
    color: rgba(0,0,0,.7);
    line-height: 1.65;
  }

  @media (max-width: 900px){
    .recentGrid{ grid-template-columns: 1fr; }
  }
  @media (max-width: 640px){
    .wrap{ padding: 1.6rem 1rem 2.8rem; }
    .heroBody, .article{ padding: 1.3rem; }
    h1{ font-size: 2.2rem; }
  }
</style>

<SiteLayout title={`${entry.data.title} | News`}>
  <main class="wrap">
    <article class="hero">
      <div class="heroBody">
        <p class="kicker">{entry.data.category ?? "News"}</p>
        <h1>{entry.data.title}</h1>
        <div class="meta">
          <span>{formatDate(entry.data.publishedAt)}</span>
          {entry.data.updatedAt && <span>Updated {formatDate(entry.data.updatedAt)}</span>}
        </div>
        <p class="summary">{entry.data.summary}</p>
      </div>

      {entry.data.heroImage && (
        <img src={assetPath(entry.data.heroImage)} alt={entry.data.heroAlt ?? entry.data.title} loading="lazy" />
      )}
    </article>

    <section class="article">
      <Content />
      <a class="backLink" href={`${base}/news`}>Back to all news</a>
    </section>

    {recentEntries.length > 0 && (
      <section class="recentSection" aria-label="Recent news">
        <div class="recentGrid">
          {recentEntries.map((item) => (
            <article class="recentCard">
              <a href={`${base}/news/${item.slug}`}>
                <h2>{item.data.title}</h2>
              </a>
              <p>{item.data.summary}</p>
              <div class="meta">
                <span>{formatDate(item.data.publishedAt)}</span>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </main>
</SiteLayout>
